// prisma/schema.prisma
/// @raw.sql CREATE EXTENSION IF NOT EXISTS citext;
/// @raw.sql CREATE EXTENSION IF NOT EXISTS pg_trgm;

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// NextAuthのUserと統合
model User {
  id             Int       @id @default(autoincrement())
  name           String?   @db.VarChar(255)
  email          String?   @db.Citext
  emailVerified  DateTime? @map("email_verified") @db.Timestamptz(6)
  image          String?   @db.VarChar(2048)
  hashedPassword String?   @map("hashed_password") @db.VarChar(255)

  // ドメイン属性
  region    String?   @db.VarChar(255)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6) // ソフトデリート用

  // Auth リレーション
  accounts Account[]
  sessions Session[]

  // ドメインリレーション
  clips             Clip[]
  playlists         Playlist[]
  favoriteClips     FavoriteClip[]
  favoritePlaylists FavoritePlaylist[]
  usersVods         UserVod[]

  /// @@partialUnique([email])
  @@map("users")
}

model Vod {
  id        Int       @id @default(autoincrement())
  code      String    @db.VarChar(50)
  name      String    @db.VarChar(255)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  clips         Clip[]
  playlistsVods PlaylistVod[]
  usersVods     UserVod[]
  vodAliases    VodAlias[]

  /// @@partialUnique([name])
  /// @@partialUnique([code])
  @@map("vods")
}

// 別名吸収用（“Prime”, “AmazonPrime” など）
model VodAlias {
  id        Int      @id @default(autoincrement())
  vodId     Int      @map("vod_id")
  alias     String   @db.Citext
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  vod Vod @relation(fields: [vodId], references: [id], onDelete: Cascade)

  @@unique([alias])
  @@index([vodId])
  @@map("vod_aliases")
}

model Clip {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  vodId      Int       @map("vod_id")
  name       String    @db.VarChar(255)
  title      String
  views      BigInt    @default(0) @db.BigInt
  startMs    Int       @map("start_ms")
  endMs      Int       @map("end_ms")
  url        String
  epnum      String?
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  vod  Vod  @relation(fields: [vodId], references: [id], onDelete: Cascade)

  favorites      FavoriteClip[]
  clipsPlaylists ClipPlaylist[]

  /// @@partialIndex([userId, createdAt])
  /// @@partialIndex([vodId, createdAt])
  @@map("clips")
}

model Playlist {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(255)
  userId    Int       @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  clipsPlaylists ClipPlaylist[]
  playlistsVods  PlaylistVod[]
  favorites      FavoritePlaylist[]

  /// @@partialUnique([userId, name])
  /// @@partialIndex([userId, createdAt])
  @@map("playlists")
}

model UserVod {
  userId    Int      @map("user_id")
  vodId     Int      @map("vod_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  vod  Vod  @relation(fields: [vodId], references: [id], onDelete: Cascade)

  @@id([userId, vodId])
  @@index([vodId])
  @@map("users_vods")
}

model ClipPlaylist {
  clipId     Int      @map("clip_id")
  playlistId Int      @map("playlist_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  clip     Clip     @relation(fields: [clipId], references: [id], onDelete: Cascade)
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@id([clipId, playlistId])
  @@index([playlistId, createdAt])
  @@map("clips_playlists")
}

model PlaylistVod {
  playlistId Int      @map("playlist_id")
  vodId      Int      @map("vod_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  vod      Vod      @relation(fields: [vodId], references: [id], onDelete: Cascade)

  @@id([playlistId, vodId])
  @@index([vodId])
  @@index([playlistId, createdAt])
  @@map("playlists_vods")
}

model FavoriteClip {
  userId    Int      @map("user_id")
  clipId    Int      @map("clip_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  clip Clip @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@id([userId, clipId])
  @@index([userId, createdAt])
  @@index([clipId])
  @@map("favorite_clips")
}

model FavoritePlaylist {
  userId     Int      @map("user_id")
  playlistId Int      @map("playlist_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@id([userId, playlistId])
  @@index([userId, createdAt])
  @@index([playlistId])
  @@map("favorite_playlists")
}

// NextAuth モデル
model Account {
  id                Int     @id @default(autoincrement())
  userId            Int     @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token") @db.Text
  accessToken       String? @map("access_token") @db.Text
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token") @db.Text
  sessionState      String? @map("session_state")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       Int      @map("user_id")
  expires      DateTime @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime @db.Timestamptz(6)

  @@id([identifier, token])
  @@map("verification_tokens")
}

