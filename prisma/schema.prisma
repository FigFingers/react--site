// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Clip {
  id            Int            @id @default(autoincrement()) // 自動採番の主キー
  clipName      String? //クリップ名
  user          String // ユーザー名
  service       String // Netflix, Primeなど
  startTime     Float // 開始時刻
  endTime       Float // 終了時刻
  url           String // 動画URLやパス
  title         String // 動画タイトル
  epnumber      String         @default("エピソード不明") // エピソード名や番号
  createdAt     DateTime       @default(now()) // 登録日時
  playlistClips PlaylistClip[]
}

model Playlist {
  id        Int            @id @default(autoincrement())
  name      String
  user      User           @relation(fields: [userId], references: [id])
  userId    String
  clips     PlaylistClip[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model PlaylistClip {
  id         Int      @id @default(autoincrement())
  playlistId Int
  clipId     Int
  order      Int       // 並び順

  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  clip       Clip     @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@index([playlistId, order])
}


model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?
  image String?

  nickname      String?
  nicknameNorm  String?   @unique
  // 認証用
  passwordHash  String? // Credentials用（Googleのみ運用なら不要）
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]

  playlists Playlist[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
