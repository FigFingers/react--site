generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Clip {
  id            Int            @id @default(autoincrement())
  clipName      String?
  user          String
  userInfo      Json?
  userId        String?
  service       String
  startTime     Float
  endTime       Float
  url           String
  title         String
  epnumber      String?
  createdAt     DateTime       @default(now())
  playlistClips PlaylistClip[]
  owner         User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Playlist {
  id        Int            @id @default(autoincrement())
  name      String
  user      User           @relation(fields: [userId], references: [id])
  userId    String
  clips     PlaylistClip[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model PlaylistClip {
  id         Int      @id @default(autoincrement())
  playlistId Int
  clipId     Int
  order      Int

  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  clip       Clip     @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@index([playlistId, order])
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  image         String?
  nickname      String?
  nicknameNorm  String?  @unique
  passwordHash  String?
  emailVerified DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  accounts      Account[]
  sessions      Session[]

  clips               Clip[]
  playlists           Playlist[]
  linkedExtensions    LinkedExtension[]
  extensionLinkTokens ExtensionLinkToken[]
}

model LinkedExtension {
  id                  Int          @id @default(autoincrement())
  userId              String
  extensionInstanceId String       @unique
  extensionAuthHash   String
  linkedAt            DateTime     @default(now())
  lastSeenAt          DateTime     @default(now())
  revokedAt           DateTime?
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncReceipts        SyncReceipt[]

  @@index([userId, revokedAt])
}

model ExtensionLinkToken {
  id        Int      @id @default(autoincrement())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model SyncReceipt {
  id                Int             @id @default(autoincrement())
  linkedExtensionId Int
  clientItemId      String
  itemType          String
  createdAt         DateTime        @default(now())
  linkedExtension   LinkedExtension @relation(fields: [linkedExtensionId], references: [id], onDelete: Cascade)

  @@unique([linkedExtensionId, clientItemId])
  @@index([linkedExtensionId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
