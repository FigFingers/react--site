AUTH_SECRET=ランダムな32〜64文字
AUTH_GOOGLE_ID=（GCPで発行したクライアントID）
AUTH_GOOGLE_SECRET=（GCPで発行したクライアントシークレット）
NEXTAUTH_URL=http://localhost:3000
DATABASE_URL=postgresql://user:password@localhost:5432/figfingers
CLIP_API_ALLOWED_ORIGINS=http://localhost:3000,chrome-extension://your-extension-id

# DB SSH トンネル（npm run dev で自動起動）
# DATABASE_URL が localhost を指している場合は必須
# ローカルに直接 PostgreSQL を立てている場合は不要（空欄でスキップされる）
DB_SSH_USER=user@your-db-server.example.com
DB_SSH_PORT=22
